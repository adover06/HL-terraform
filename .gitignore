# в”Ђв”Ђ macOS в”Ђв”Ђ
.DS_Store

# в”Ђв”Ђ Terraform: secrets + state вЂ” NEVER commit в”Ђв”Ђ
*.tfvars            # real var files hold your API token (*.tfvars.example is safe вЂ” different suffix)
*.tfstate           # state stores secrets/IPs in PLAINTEXT
*.tfstate.*
.terraform/         # downloaded provider binaries
crash.log
# .terraform.lock.hcl is committed ON PURPOSE (pins provider versions) вЂ” do not add it here.

# в”Ђв”Ђ Go (the broker, coming later) в”Ђв”Ђ
/bin/
*.test
