# Copy this to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored — it holds your API token, never commit it.

proxmox_endpoint  = "https://192.168.X.X:8006/"
proxmox_api_token = "root@pam!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
ssh_public_key    = "ssh-ed25519 AAAA...your-key... you@host"

# node_name and template_id default to "pve" / 500 — uncomment to override:
# node_name   = "pve"
# template_id = 500
